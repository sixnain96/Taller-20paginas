              "raw": "{{baseUrl}}/books?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get book by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/books/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books",
                "1"
              ]
            }
          }
        }
      ]
    },
